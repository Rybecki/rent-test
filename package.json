{
  "name": "cherrysign",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -n api,vite -c blue,green \"npm run dev:api\" \"vite\"",
    "dev:api": "node server/index.mjs",
    "dev:php": "php -S localhost:8080 router.php",
    "dev:vite": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "knockout-logo": "node scripts/knockout-logo-bg.mjs",
    "logo:prepare": "node scripts/prepare-logo-png.mjs",
    "db:test": "node scripts/test-db-connection.mjs",
    "db:migrate": "node scripts/migrate.mjs",
    "db:patch-email": "node scripts/patch-client-email.mjs",
    "db:patch-bikes": "node scripts/patch-bike-model-counts.mjs",
    "db:patch-name": "node scripts/patch-name-columns.mjs",
    "db:patch-issuer": "node scripts/patch-issuer-name-columns.mjs",
    "db:patch-invoice": "node scripts/patch-invoice-columns.mjs",
    "db:verify": "node scripts/db-verify.mjs",
    "db:setup": "node scripts/db-setup.mjs",
    "test:api": "node scripts/test-api-documents.mjs",
    "test:pdf": "node scripts/test-pdf-sample.mjs",
    "pack:deploy": "npm run build && node scripts/pack-deploy.mjs",
    "pack:server": "npm run pack:deploy"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dejavu-fonts-ttf": "^2.37.3",
    "express": "^5.1.0",
    "express-session": "^1.18.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "nodemailer": "^8.0.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-signature-canvas": "^1.1.0-alpha.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-signature-canvas": "^1.0.7",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "mysql2": "^3.22.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}

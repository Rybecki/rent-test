# Tryb testowy (USE_LOCAL_STORAGE=true w appConfig.ts) — baza i SMTP nie są wymagane.
# Poniższe zmienne dotyczą tylko npm run dev:full (API + MySQL).

API_PORT=3002
CLIENT_ORIGIN=http://localhost:3001
SESSION_SECRET=zmien-na-losowy-ciag-znakow

DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Seed użytkowników (npm run db:migrate) — ustaw tylko lokalnie w .env, nie commituj haseł
# MIGRATE_USERS=[{"email":"admin@example.com","password":"...","role":"admin"}]

# Testy API (npm run test:api-documents)
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Rentally" <kontakt@rent-aboco.pl>
NOTIFY_EMAILS=biuro@ja-yhymm.pl,kontakt@rent-aboco.pl
OFFICE_EMAIL=kontakt@rent-aboco.pl
